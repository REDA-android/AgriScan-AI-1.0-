# GEMINI_API_KEY: Required for Gemini AI API calls (Server-side).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: (OPTIONNEL) Pour utiliser l'IA directement sur le téléphone (Android APK)
# sans passer par le serveur. Moins sécurisé mais idéal pour un APK autonome.
VITE_GEMINI_API_KEY=""

# VITE_API_URL: (OPTIONNEL) L'URL de votre serveur backend si l'APK doit communiquer 
# avec un serveur hébergé (ex: https://votre-serveur.run.app) au lieu du client direct.
VITE_API_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDINARY CREDENTIALS
# Required for image storage. Sign up at Cloudinary -> Settings -> Enable "Unsigned uploading"
VITE_CLOUDINARY_CLOUD_NAME="your-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="your-unsigned-preset"

# WEATHER API KEYS (OPTIONNELLES)
# L'application utilise Open-Meteo par défaut (gratuit, sans clé). 
# Pour enrichir les données (requête multi-sources), vous pouvez ajouter les clés suivantes :
OPENWEATHERMAP_API_KEY=""
WEATHERAPI_API_KEY=""
VISUALCROSSING_API_KEY=""

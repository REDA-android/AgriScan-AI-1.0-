rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, role, createdAt
    
    // Collection: observations
    // Fields: userId, imageUrl, family, species, variety, location, phenotypicTraits, userNotes, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isAuthenticated() && 
        (
          ('email' in request.auth.token && (request.auth.token.email == "relkrouchni@gmail.com" || request.auth.token.email == "elkrouchni@gmail.com")) || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessStatus == 'approved')
        );
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          ('email' in request.auth.token && (request.auth.token.email == "relkrouchni@gmail.com" || request.auth.token.email == "elkrouchni@gmail.com")) || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'accessStatus']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['owner', 'user', 'viewer', 'admin'] &&
             data.accessStatus in ['pending', 'approved', 'rejected'];
    }

    function isValidObservation(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'family', 'species', 'variety', 'location']) &&
             data.userId is string &&
             data.imageUrl is string &&
             data.location.lat is number &&
             data.location.lng is number &&
             (!('isDeletedByCreator' in data) || data.isDeletedByCreator is bool) &&
             (!('status' in data) || data.status in ['pending', 'uploading', 'analyzing', 'completed', 'error', 'syncing']);
    }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // New users can create their profile as 'pending' and 'viewer' (default)
      allow create: if isAuthenticated() && isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == 'viewer' &&
                      (request.resource.data.accessStatus == 'pending' || (request.auth.provider == 'anonymous' && request.resource.data.accessStatus == 'approved'));
      // Admins can update anything, users can only update their own profile if it doesn't change role or status
      allow update: if isAuthenticated() && 
                      (isAdmin() || 
                       (isOwner(userId) && 
                        isValidUser(request.resource.data) && 
                        request.resource.data.role == resource.data.role && 
                        request.resource.data.accessStatus == resource.data.accessStatus));
    }

    match /observations/{obsId} {
      // Non-admins can only read observations that aren't soft-deleted by the creator
      allow read: if isApproved() && (isAdmin() || !('isDeletedByCreator' in resource.data) || resource.data.isDeletedByCreator == false);
      allow create: if isApproved() && request.resource.data.userId == request.auth.uid && isValidObservation(request.resource.data);
      allow update: if isApproved() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidObservation(request.resource.data);
      // Hard delete only allowed for admins
      allow delete: if isAdmin();
    }
  }
}
